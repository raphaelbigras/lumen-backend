generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
  USER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id             String    @id @default(uuid())
  keycloakId     String    @unique
  email          String    @unique
  firstName      String
  lastName       String
  role           Role      @default(USER)
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  submittedTickets   Ticket[]          @relation("SubmittedTickets")
  assignedTickets    TicketAssignment[]
  comments           TicketComment[]
  events             TicketEvent[]

  @@map("users")
}

model Department {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  users     User[]
  tickets   Ticket[]

  @@map("departments")
}

model Ticket {
  id           String         @id @default(uuid())
  title        String
  description  String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  submitterId  String
  submitter    User           @relation("SubmittedTickets", fields: [submitterId], references: [id])
  departmentId String?
  department   Department?    @relation(fields: [departmentId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  resolvedAt   DateTime?
  categoryId   String?
  category     Category?  @relation(fields: [categoryId], references: [id])

  comments     TicketComment[]
  attachments  Attachment[]
  assignments  TicketAssignment[]
  events       TicketEvent[]

  @@map("tickets")
}

model TicketComment {
  id        String    @id @default(uuid())
  ticketId  String
  ticket    Ticket    @relation(fields: [ticketId], references: [id])
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("ticket_comments")
}

model TicketEvent {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])
  type      String
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  @@map("ticket_events")
}

model Attachment {
  id          String    @id @default(uuid())
  ticketId    String
  ticket      Ticket    @relation(fields: [ticketId], references: [id])
  filename    String
  mimeType    String
  size        Int
  storageKey  String
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  @@map("attachments")
}

model TicketAssignment {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  agentId   String
  agent     User     @relation(fields: [agentId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([ticketId, agentId])
  @@map("ticket_assignments")
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  tickets     Ticket[]

  @@map("categories")
}
